# ---------------------------------------------------------------------------
# Xi's Adaptive Clothing — environment variables
#
# Copy this file to `.env.local` for local development, and set the same
# variables in the Vercel dashboard (Project → Settings → Environment
# Variables) for Preview and Production. NEVER commit real values.
#
# NEXT_PUBLIC_* variables are exposed to the browser by design — never put a
# secret in one. All other variables here are SERVER-ONLY secrets and are read
# only from server code (app/api/*, lib/server/*).
# ---------------------------------------------------------------------------

# --- Public (browser-visible) ---------------------------------------------

# Public support / privacy contact address shown in the UI. Use a NEUTRAL
# PROJECT inbox, not a personal one. If unset, the UI falls back to
# "privacy@example.com" — configure a real address before launch.
NEXT_PUBLIC_CONTACT_EMAIL=privacy@example.com

# Canonical site URL for SEO/OG/sitemap. On Vercel this is auto-derived from
# VERCEL_PROJECT_PRODUCTION_URL if omitted.
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# --- Server-only secrets ---------------------------------------------------

# Upstash Redis (or Vercel KV) — REQUIRED in production for the /api/submit
# product-suggestion endpoint to persist submissions. Create a database via the
# Vercel Marketplace "Upstash" integration (which sets KV_REST_API_*) or in the
# Upstash console (which gives UPSTASH_REDIS_REST_*). Either pair works.
# Without these, /api/submit returns 503 in production (it never silently drops
# data); locally it uses an ephemeral in-memory store.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Salt used to one-way hash IP addresses for rate-limiting / duplicate
# detection so raw IPs are never stored. Set a long random string in
# production (e.g. `openssl rand -hex 32`). If unset a weak build-time fallback
# is used.
SUBMISSION_HASH_SALT=
