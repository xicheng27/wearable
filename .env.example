# ---------------------------------------------------------------------------
# Xi's Adaptive Clothing — environment variables
#
# This app has NO server secrets. It has no database, no auth and no API
# routes, so every value here is a NEXT_PUBLIC_* variable that is, by design,
# visible in the browser. Do NOT put private keys/tokens in this project — if
# you ever add a backend, keep its secrets in non-NEXT_PUBLIC_ variables and
# read them only from server-only modules.
#
# Copy this file to `.env.local` for local development, and set the same
# variables in the Vercel dashboard (Project → Settings → Environment
# Variables) for Preview and Production.
# ---------------------------------------------------------------------------

# Public support / privacy contact address shown in the UI (contact & privacy
# pages, submission form). Use a NEUTRAL PROJECT inbox, not a personal one.
# If unset, the UI falls back to "privacy@example.com" — configure a real
# address before launch.
NEXT_PUBLIC_CONTACT_EMAIL=privacy@example.com

# Canonical site URL, used for SEO/OG/sitemap absolute links. On Vercel this is
# auto-derived from VERCEL_PROJECT_PRODUCTION_URL if omitted.
# NEXT_PUBLIC_SITE_URL=https://your-domain.example
